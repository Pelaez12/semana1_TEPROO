	void Listado() {
		Imprimir("Nombre\tApellido\tDNI\tcorreo\tTelefono");
		for (int i = 0; i < ae.Tamaño(); i++) {
			Imprimir(""+ae.Obtener(i).getNom()+"\t"+ae.Obtener(i).getApe()+"\t"+ae.Obtener(i).getDni()+"\t"+ae.Obtener(i).getCorreo()+
